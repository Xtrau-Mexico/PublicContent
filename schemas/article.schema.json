{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xtrau.mx/schemas/article.schema.json",
  "title": "Xtrau public article metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "slug", "description", "category", "status", "locale", "updatedAt", "owner"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,99}$" },
    "type": { "enum": ["support", "guide", "legal", "blog"] },
    "title": { "type": "string", "minLength": 3, "maxLength": 160 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*$" },
    "description": { "type": "string", "minLength": 20, "maxLength": 320 },
    "category": { "type": "string" },
    "status": { "enum": ["draft", "published", "archived"] },
    "locale": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
    "updatedAt": { "type": "string", "format": "date" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "owner": { "type": "string", "pattern": "^[a-z][a-z-]{1,49}$" },
    "redirectFrom": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*$" } },
    "productScope": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,49}$" } },
    "tags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "order": { "type": "integer", "minimum": 0 },
    "featured": { "type": "boolean" },
    "legal": { "type": "object", "additionalProperties": false, "properties": { "effectiveAt": { "type": "string", "format": "date" }, "jurisdiction": { "type": "string", "minLength": 2, "maxLength": 100 } } }
  },
  "allOf": [
    { "if": { "properties": { "status": { "const": "published" } } }, "then": { "required": ["lastReviewedAt"] } },
    { "if": { "properties": { "type": { "const": "support" } } }, "then": { "properties": { "category": { "enum": ["account", "orders", "payments", "shipping", "warranty", "setup", "troubleshooting"] } } } },
    { "if": { "properties": { "type": { "const": "guide" } } }, "then": { "properties": { "category": { "const": "guides" } } } },
    { "if": { "properties": { "type": { "const": "legal" } } }, "then": { "properties": { "category": { "const": "legal" } } } },
    { "if": { "properties": { "type": { "const": "blog" } } }, "then": { "properties": { "category": { "const": "blog" } } } }
  ]
}
